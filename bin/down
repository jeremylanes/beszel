#!/usr/bin/env bash

# Go to the project root
cd "$(dirname "$0")/.."

# Stop main services
echo "Stopping main services (docker-compose.yml)..."
docker compose -f docker-compose.yml --env-file ./.env down

# Stop systems services
echo "Stopping systems services (systems/docker-compose.yml)..."
docker compose -f systems/docker-compose.yml --env-file ./.env down

