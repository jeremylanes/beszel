#!/usr/bin/env bash
#
# Usage:
#   bin/up            — start systems services (background) then main services (foreground)
#   bin/up system     — start systems services only (background)

# Go to the project root
cd "$(dirname "$0")/.."

if [ "$1" = "system" ]; then
  # Run systems services only
  echo "Starting systems services (systems/docker-compose.yml)..."
  docker compose -f systems/docker-compose.yml --env-file ./.env up --build
else
  # Run systems services in background, then main services in foreground
  echo "Starting systems services (systems/docker-compose.yml)..."
  docker compose -f systems/docker-compose.yml --env-file ./.env up -d --build

  echo "Starting main services (docker-compose.yml)..."
  docker compose -f docker-compose.yml --env-file ./.env up --build
fi
