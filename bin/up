#!/usr/bin/env bash

# Go to the project root
cd "$(dirname "$0")/.."

# Build with update
# docker compose -f docker-compose.yml build --no-cache

# Run systems services in background
echo "Starting systems services (systems/docker-compose.yml)..."
docker compose -f systems/docker-compose.yml --env-file ./.env up -d --build

# Run main services
echo "Starting main services (docker-compose.yml)..."
docker compose -f docker-compose.yml --env-file ./.env up --build
